PORT=3000
# Select AI provider: groq | gemini
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini (Google)
GEMINI_API_KEY=
# Optional: if you set a wrong value, the backend will attempt to auto-pick a supported model.
GEMINI_MODEL=gemini-2.5-flash
HF_API_TOKEN=
HF_MODEL=google/gemma-2-2b-it
HF_PROVIDER=hf-inference
AI_HARD_TIMEOUT_MS=55000
